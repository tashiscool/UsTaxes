{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "lib": ["ES2022", "WebWorker", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "ustaxes/*": ["../src/*"]
    }
  },
  "include": ["src", "test"]
}
