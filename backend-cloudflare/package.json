{
  "name": "@ustaxes/backend-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "test": "vitest run",
    "test:core": "vitest run --exclude test/worker/cloudflareRuntime.e2e.test.ts",
    "test:runtime:auth": "RUNTIME_SMOKE_FILTER=auth node ./scripts/runtime-smoke-checks.mjs",
    "test:runtime:derived-facts": "RUNTIME_SMOKE_FILTER=derivedFacts node ./scripts/runtime-smoke-checks.mjs",
    "test:runtime:workbook": "RUNTIME_SMOKE_FILTER=workbook node ./scripts/runtime-smoke-checks.mjs",
    "test:runtime:advanced": "RUNTIME_SMOKE_FILTER=advanced node ./scripts/runtime-smoke-checks.mjs",
    "test:runtime": "node ./scripts/runtime-smoke-checks.mjs",
    "test:runtime:full": "vitest run test/worker/cloudflareRuntime.e2e.test.ts --testTimeout 240000",
    "test:taxflow:e2e": "bash ./scripts/run-taxflow-local-e2e.sh",
    "test:comprehensive": "vitest run test/manual/taxCalculationService.comprehensive.manual.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "node ./scripts/test-all.mjs",
    "test:watch": "vitest",
    "scenario:matrix:sync": "node ./scripts/build-ats-scenario-matrix.mjs",
    "scenario:coverage:report": "node ./scripts/generate-scenario-coverage-report.mjs",
    "capability:matrix": "node ./scripts/generate-capability-matrix.mjs",
    "irs:ops:sync": "node ./scripts/sync-irs-operational-feeds.mjs",
    "irs:readiness:report": "node ./scripts/generate-irs-readiness-report.mjs",
    "d1:migrate:local": "wrangler d1 migrations apply USTAXES_DB --local",
    "d1:seed:local": "wrangler d1 execute USTAXES_DB --local --file scripts/seed.sql",
    "check": "tsc --noEmit",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "deploy:pipeline:production": "bash ./scripts/deploy-prod.sh",
    "d1:migrate:staging": "wrangler d1 migrations apply USTAXES_DB --env staging --remote",
    "d1:migrate:production": "wrangler d1 migrations apply USTAXES_DB --env production --remote",
    "cf:verify": "bash ./scripts/verify_cloudflare_token.sh",
    "cf:bootstrap:staging": "CLOUDFLARE_WORKER_ENV=staging bash ./scripts/bootstrap_cloudflare_resources.sh",
    "cf:bootstrap:production": "CLOUDFLARE_WORKER_ENV=production bash ./scripts/bootstrap_cloudflare_resources.sh",
    "cf:secrets:staging": "CLOUDFLARE_WORKER_ENV=staging bash ./scripts/sync_wrangler_secrets.sh",
    "cf:secrets:production": "CLOUDFLARE_WORKER_ENV=production bash ./scripts/sync_wrangler_secrets.sh",
    "tail:staging": "wrangler tail --env staging",
    "tail:production": "wrangler tail --env production"
  },
  "dependencies": {
    "hono": "^4.6.11",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260220.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.10.0"
  }
}
